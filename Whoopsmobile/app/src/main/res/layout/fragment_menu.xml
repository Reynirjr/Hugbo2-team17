<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F6F4E4">

    <!-- Header banner: logo row + filter tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#291317"
        android:orientation="vertical"
        android:elevation="4dp">

        <!-- Top row: logo (center) + last order shortcut (top end) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="start|center_vertical">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:src="@drawable/hagavagninn_logo_hvitt"
                    android:contentDescription="@string/menu"
                    android:scaleType="fitCenter"
                    android:adjustViewBounds="true"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnLastOrderStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:visibility="gone"
                android:focusable="true"
                android:clickable="true"
                android:contentDescription="@string/order_status_shortcut_label">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <View
                        android:id="@+id/statusShortcutStep1"
                        android:layout_width="7dp"
                        android:layout_height="7dp"
                        android:background="@drawable/circle_inactive" />

                    <View
                        android:id="@+id/statusShortcutLine1"
                        android:layout_width="12dp"
                        android:layout_height="2dp"
                        android:layout_marginStart="2dp"
                        android:layout_marginEnd="2dp"
                        android:background="@drawable/progress_line_inactive" />

                    <View
                        android:id="@+id/statusShortcutStep2"
                        android:layout_width="7dp"
                        android:layout_height="7dp"
                        android:background="@drawable/circle_inactive" />

                    <View
                        android:id="@+id/statusShortcutLine2"
                        android:layout_width="12dp"
                        android:layout_height="2dp"
                        android:layout_marginStart="2dp"
                        android:layout_marginEnd="2dp"
                        android:background="@drawable/progress_line_inactive" />

                    <View
                        android:id="@+id/statusShortcutStep3"
                        android:layout_width="7dp"
                        android:layout_height="7dp"
                        android:background="@drawable/circle_inactive" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/order_status_shortcut_label"
                    android:textColor="#F6F4E4"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </FrameLayout>

        <!-- Filter tabs row inside the banner -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/chipAll"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/filter_all"
                android:textColor="#F6F4E4"
                android:textSize="13sp"
                android:paddingTop="9dp"
                android:paddingBottom="9dp"/>

            <TextView
                android:id="@+id/chipVegetarian"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/filter_vegetarian"
                android:textColor="#F6F4E4"
                android:textSize="13sp"
                android:paddingTop="9dp"
                android:paddingBottom="9dp"/>

            <TextView
                android:id="@+id/chipSides"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/filter_sides"
                android:textColor="#F6F4E4"
                android:textSize="13sp"
                android:paddingTop="9dp"
                android:paddingBottom="9dp"/>

            <TextView
                android:id="@+id/chipDrinks"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/filter_drinks"
                android:textColor="#F6F4E4"
                android:textSize="13sp"
                android:paddingTop="9dp"
                android:paddingBottom="9dp"/>

        </LinearLayout>
    </LinearLayout>

    <!-- Empty State -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/nothing_on_menu"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#555555"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginTop="40dp"/>

    <!-- Menu List with bottom overlay cart button -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvItems"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="12dp"
            android:paddingBottom="88dp"
            android:background="#F6F4E4"
            android:clipToPadding="false"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/basketBarContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="12dp"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"
            android:contentDescription="@string/your_basket"
            app:cardBackgroundColor="@color/brand_primary"
            app:cardCornerRadius="999dp"
            app:cardElevation="0dp"
            app:rippleColor="#40FFFFFF"
            app:strokeColor="@android:color/transparent"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/your_basket"
                    android:textColor="@color/cream"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/basketBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:minWidth="24dp"
                    android:minHeight="24dp"
                    android:background="@drawable/badge_background"
                    android:gravity="center"
                    android:textColor="@color/brand_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    android:paddingStart="7dp"
                    android:paddingEnd="7dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>

</LinearLayout>
